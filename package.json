{
  "name": "qr-generator-desktop",
  "version": "1.0.0",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "vite:dev": "vite",
    "electron:dev": "cross-env ELECTRON_START_URL=http://localhost:5173 electron .",
    "dev": "concurrently \"npm run vite:dev\" \"npm run electron:dev\"",
    "build": "vite build",
    "electron:build": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.2.0"
  },
  "build": {
    "appId": "com.davidjosh.qrgenerator",
    "productName": "Offline QR Generator",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}