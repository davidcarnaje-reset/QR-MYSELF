{
  "name": "qr-generator-desktop",
  "version": "1.0.0",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "vite:dev": "vite",
    "electron:dev": "cross-env ELECTRON_START_URL=http://localhost:5173 electron .",
    "dev": "concurrently \"npm run vite:dev\" \"npm run electron:dev\"",
    "build": "vite build",
    "electron:build": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.21.0",
    "qr-code-styling": "^1.9.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "tailwindcss": "^4.3.1",
    "vite": "^8.1.0"
  },
  "build": {
    "appId": "com.davidjosh.qrgenerator",
    "productName": "Offline QR Generator",
    "directories": {
      "output": "dist_electron_build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}
